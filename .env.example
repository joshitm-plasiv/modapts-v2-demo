# Required for backend CLI usage (not needed for frontend demo)
MODAPTS_LLM_PROVIDER=anthropic        # anthropic | openai | mistral | ollama
MODAPTS_LLM_MODEL=claude-sonnet-4-20250514
MODAPTS_API_KEY=sk-ant-...

# Optional
MODAPTS_FEWSHOT_CAP=20                # Max few-shot corrections in prompt (default: 20)
MODAPTS_CORRECTIONS_PATH=modapts_corrections.json
MODAPTS_ACCEPTED_PATH=modapts_accepted.json
OLLAMA_BASE_URL=http://localhost:11434 # Only for ollama provider
